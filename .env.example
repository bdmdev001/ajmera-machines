# ============================================================================
#  ENV TEMPLATE — copy to ".env" and fill in real values. NO SECRETS HERE.
#  cp .env.example .env
# ============================================================================

# ── Database: MongoDB Atlas ────────────────────────────────────────────────
# Atlas -> Connect -> Drivers. Percent-encode any special chars in the password
# (e.g. "@" -> %40, "#" -> %23). Keep the /<dbname> segment.
MONGODB_URI="mongodb+srv://<user>:<url-encoded-password>@<cluster-host>/<dbname>?retryWrites=true&w=majority&appName=Cluster0"

# ── Cloudinary (image hosting) ─────────────────────────────────────────────
# Dashboard -> Account Details. Use these three discrete vars only (no CLOUDINARY_URL).
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
CLOUDINARY_UPLOAD_FOLDER="ajmera/machines"

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Admin login + session ──────────────────────────────────────────────────
# Use a long random string for ADMIN_SESSION_TOKEN (e.g. `openssl rand -hex 32`).
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change_me"
ADMIN_SESSION_TOKEN="generate_a_long_random_secret"

# ── Email (SMTP via Nodemailer) ────────────────────────────────────────────
# Enquiry/contact notifications are emailed to ADMIN_EMAIL. Leave blank to
# disable email (enquiries are still saved). Gmail: use an App Password.
MAIL_HOST="smtp.gmail.com"
MAIL_PORT="587"
MAIL_USER="your_smtp_user@example.com"
MAIL_PASS="your_smtp_password_or_app_password"
MAIL_FROM="Ajmera Enterprise <your_smtp_user@example.com>"
ADMIN_EMAIL="support@bdminfotech.com"
